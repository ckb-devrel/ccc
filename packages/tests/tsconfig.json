{
  "compilerOptions": {
    "target": "es2022",
    "types": ["node"],
    "incremental": true,
    "allowJs": true,
    "importHelpers": false,
    "declaration": true,
    "declarationMap": true,
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "esModuleInterop": true,
    "strict": true,
    "noImplicitAny": true,
    "strictBindCallApply": true,
    "strictNullChecks": true,
    "alwaysStrict": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "rootDir": "./tests",
    "outDir": "./dist"
  },
  "include": ["tests/**/*"]
}
