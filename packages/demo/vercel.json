{
  "buildCommand": "pnpm build",
  "outputDirectory": ".next",
  "headers": [
    {
      "source": "/",
      "headers": [
        { "key": "Document-Isolation-Policy", "value": "isolate-and-credentialless" },
        { "key": "Cross-Origin-Resource-Policy", "value": "cross-origin" }
      ]
    }
  ]
}
