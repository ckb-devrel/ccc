{
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test": "pnpm run -C packages/tests test && vitest",
    "test:ci": "pnpm run -C packages/tests test && vitest run",
    "test:cov": "vitest run --coverage",
    "build:prepare": "pnpm -r --filter !./packages/tests --filter !./packages/demo --filter !./packages/faucet --filter !./packages/examples --filter !./packages/playground --filter !./packages/docs --filter !. install",
    "build": "pnpm -r --filter !./packages/tests --filter !./packages/demo --filter !./packages/faucet --filter !./packages/examples --filter !./packages/playground --filter !./packages/docs run build",
    "build:all": "pnpm -r run build",
    "lint": "pnpm -r run lint",
    "format": "pnpm -r run format",
    "sync:config": "pnpm -r --filter !./packages/demo --filter !./packages/faucet --filter !./packages/playground --filter !./packages/docs -c exec \"cp ../../config/* . && cp ../../config/.* .\"",
    "docs": "typedoc"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@types/jest": "^30.0.0",
    "@vitest/coverage-v8": "4.1.10",
    "jest": "30.4.2",
    "ts-jest": "^29.4.11",
    "typedoc": "0.28.20",
    "typedoc-material-theme": "^1.4.1",
    "typedoc-plugin-extras": "^4.0.1",
    "typedoc-plugin-ga": "^1.1.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "packageManager": "pnpm@11.8.0"
}
